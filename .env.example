# Server
PORT=3000

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cloud_pos
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-cloud-jwt-secret-change-in-production

# Webhook
WEBHOOK_SECRET=shared-secret-between-cloud-and-pos

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
